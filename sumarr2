#include<stdio.h>
int main()
	{
	int r,c,i,j;
	printf("enter number of rows and columns:\n");
	scanf("%d %d",&r,&c);
	int a[r][c],b[r][c],s[r][c];
	printf("enter the elements of first matrix:\n");
	for(i=0;i<r;i++)
	{
	for(j=0;j<c;j++)
	{
	scanf("%d",&a[i][j]);
	}
	}
	printf("enter the elements of second matrix:\n");
	for(i=0;i<r;i++)
	{
	for(j=0;j<c;j++)
	{
	scanf("%d",&b[i][j]);
	}
	}
	//sum of two matrices
	for(i=0;i<r;i++)
	{
	for(j=0;j<c;j++)
	{
	s[i][j]=a[i][j]+b[i][j];
	}
	}
	//to print sum
	printf("sum is:\n");
	for(i=0;i<r;i++)
	{
	for(j=0;j<c;j++)
	{
	printf("%d ",s[i][j]);
	}
	printf("\n");
	}
	printf("25331A05E1");
	return 0;
	}
	
