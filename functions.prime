#include &lt;stdio.h&gt;
int isPrime(int num);
int main()
{
int number;
printf(&quot;Enter a number: &quot;);
scanf(&quot;%d&quot;, &amp;number);
if (isPrime(number))
printf(&quot;%d is a Prime number.\n&quot;, number);
else
printf(&quot;%d is Not a Prime number.\n&quot;, number);
return 0;
}
int isPrime(int num) {
int i;
if (num &lt;= 1)
return 0;
for (i = 2; i &lt;= num / 2; i++)
{
if (num % i == 0)
return 0;
}
return 1;
}
